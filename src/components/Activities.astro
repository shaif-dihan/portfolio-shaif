---
const activities = [
  {
    role: "General Secretary",
    org: "English and Career Club, KUET",
  },
  {
    role: "Workshop Manager",
    org: "HACK (Hardware Acceleration Club), KUET",
  },
  {
    role: "Vice President",
    org: "CYBORG (Cyber Gaming Club of KUET)",
  },
  {
    role: "Organizing Committee",
    org: "Bitfest 2019 (2nd CSE Festival), KUET",
  },
  {
    role: "Program Coordinator",
    org: "National High School Programming Contest (2016, 2017), Khulna Division",
  },
];

const achievements = [
  "Bangladesh Math Olympiad — Champion (2007)",
  "Bangladesh Math Olympiad — Runner-up (2011)",
];
---

<section id="activities" class="px-6 py-24">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-2xl font-bold tracking-tight">Beyond Code</h2>

    <div class="mt-12 grid gap-12 md:grid-cols-2">
      <div>
        <h3
          class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500"
        >
          Leadership & Activities
        </h3>
        <ul class="space-y-3">
          {
            activities.map((a) => (
              <li class="text-sm text-gray-700 dark:text-gray-300">
                <span class="font-medium text-gray-900 dark:text-gray-100">
                  {a.role}
                </span>
                <span class="text-gray-500 dark:text-gray-500"> — </span>
                {a.org}
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3
          class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500"
        >
          Achievements
        </h3>
        <ul class="space-y-3">
          {
            achievements.map((a) => (
              <li class="text-sm text-gray-700 dark:text-gray-300">
                <span class="mr-2 text-gray-400 dark:text-gray-600">★</span>
                {a}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
