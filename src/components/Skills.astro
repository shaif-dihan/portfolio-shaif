---

<section id="skills" class="px-6 py-24">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-2xl font-bold tracking-tight">Skills</h2>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        categories.map((cat) => (
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500">
              {cat.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-700 dark:border-gray-700 dark:text-gray-300">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
