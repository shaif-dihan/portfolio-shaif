---
type Project = {
  name: string;
  description: string;
  highlights?: string[];
  tags: string[];
  platforms: string[];
  links?: { label: string; url: string }[];
};

type Group = {
  category: string;
  projects: Project[];
};

const groups: Group[] = [
  {
    category: "FinTech & Web3",
    projects: [
      {
        name: "Remit & Go",
        description:
          "Non-custodial crypto wallet on Polygon with USDT/POL transfers and fiat on/off-ramp.",
        highlights: ["Encrypted keys", "Polygon", "Fiat ramp"],
        tags: ["Flutter", "Web3"],
        platforms: ["Android"],
      },
    ],
  },
  {
    category: "VPN & Security",
    projects: [
      {
        name: "EnovaVPN",
        description:
          "Flagship VPN with obfuscated IPsec/V2Ray/WireGuard for DPI bypass.",
        highlights: ["DPI bypass", "Kill Switch", "DoH"],
        tags: ["Flutter", "Native Channels", "MVVM"],
        platforms: ["Android", "iOS", "macOS", "Desktop", "Android TV", "FireTV"],
        links: [{ label: "enovavpn.com", url: "https://enovavpn.com/" }],
      },
      {
        name: "SharkVPN",
        description:
          "Native channeling for OpenVPN, WireGuard, V2Ray with cert generation.",
        highlights: ["Multi-protocol", "Native bridges"],
        tags: ["Flutter", "Kotlin", "Swift"],
        platforms: ["Android", "iOS", "macOS", "Desktop", "Android TV", "FireTV"],
        links: [
          { label: "securesharkvpn.com", url: "https://securesharkvpn.com/" },
        ],
      },
      {
        name: "RocketVPN",
        description: "White-label VPN with store-compliant releases.",
        tags: ["Flutter", "White-label"],
        platforms: ["Android", "iOS", "macOS", "Desktop", "Android TV", "FireTV"],
      },
      {
        name: "AudraVPN",
        description: "White-label VPN client.",
        tags: ["Flutter", "White-label"],
        platforms: ["Android", "iOS", "macOS", "Desktop", "Android TV", "FireTV"],
      },
      {
        name: "ZauberVPN",
        description: "White-label VPN client.",
        tags: ["Flutter", "White-label"],
        platforms: ["Android", "iOS", "macOS", "Desktop", "Android TV", "FireTV"],
      },
    ],
  },
  {
    category: "E-commerce",
    projects: [
      {
        name: "Romoni",
        description:
          "Refactored e-commerce app with Bkash/SSL Commerz, referrals, in-app feed.",
        highlights: ["Bkash", "Referrals", "Analytics"],
        tags: ["Flutter", "Firebase"],
        platforms: ["Android", "iOS"],
        links: [{ label: "romoni.com.bd", url: "https://romoni.com.bd/" }],
      },
    ],
  },
  {
    category: "Real-time & Social",
    projects: [
      {
        name: "ChitChat",
        description:
          "Real-time voice messaging, calling, and voice rooms over WebRTC.",
        highlights: ["WebRTC", "Voice rooms", "Reactive"],
        tags: ["Flutter", "WebSockets"],
        platforms: ["Android", "iOS"],
      },
    ],
  },
  {
    category: "Ed-tech",
    projects: [
      {
        name: "Tota",
        description:
          "Educational app with speech accuracy scoring and caption summarization.",
        highlights: ["Speech AI", "Model tests"],
        tags: ["Flutter", "REST APIs"],
        platforms: ["Android", "iOS"],
      },
    ],
  },
  {
    category: "Loyalty & Deals",
    projects: [
      {
        name: "DealFinder",
        description:
          "Deal discovery with QR-based activation. CustomPainter UI for performance.",
        highlights: ["QR activation", "CustomPainter"],
        tags: ["Flutter"],
        platforms: ["Android", "iOS"],
        links: [
          { label: "dealfinder.com.bd", url: "https://dealfinder.com.bd/" },
        ],
      },
    ],
  },
  {
    category: "Consumer",
    projects: [
      {
        name: "Medha",
        description:
          "Firebase auth (Apple/Google/Facebook), push notifications, Retrofit APIs.",
        tags: ["Flutter", "Firebase", "Retrofit"],
        platforms: ["Android", "iOS"],
      },
      {
        name: "Deen",
        description:
          "Firebase auth, push notifications, REST API integrations.",
        tags: ["Flutter", "Firebase"],
        platforms: ["Android", "iOS"],
      },
    ],
  },
  {
    category: "Enterprise (PRAN-RFL)",
    projects: [
      {
        name: "PRG Snacks Cart",
        description:
          "Native Android with employee ID barcode auth for factory food sales.",
        highlights: ["Barcode auth"],
        tags: ["Java", "OracleDB"],
        platforms: ["Android"],
      },
      {
        name: "Vision Warranty Plus",
        description:
          "Secure activation flows and automated warranty claim processing.",
        tags: ["Java", "DotNet API"],
        platforms: ["Android"],
      },
      {
        name: "PRG Oil Dispatch",
        description:
          "Automated transport vehicle slip generation with real-time logistics sync.",
        tags: ["Java", "OracleDB"],
        platforms: ["Android"],
      },
    ],
  },
];

const platformShort: Record<string, string> = {
  Android: "Android",
  iOS: "iOS",
  macOS: "macOS",
  Desktop: "Desktop",
  "Android TV": "AndroidTV",
  FireTV: "FireTV",
};
---

<section id="projects" class="bg-gray-50/50 px-6 py-24 dark:bg-gray-900/50">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-2xl font-bold tracking-tight">Projects</h2>
    <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
      15 apps shipped across enterprise, consumer, FinTech, security, and Web3
      domains.
    </p>
    <div class="mt-12 space-y-12">
      {
        groups.map((group) => (
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500">
              {group.category}
            </h3>
            <div class="overflow-hidden rounded-xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900">
              {group.projects.map((project, idx) => (
                <div
                  class:list={[
                    "p-4 sm:p-5",
                    idx > 0 &&
                      "border-t border-gray-200 dark:border-gray-800",
                  ]}
                >
                  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                    <div class="flex items-baseline gap-2">
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100">
                        {project.name}
                      </h4>
                      {project.links && project.links.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {project.links.map((link) => (
                            <a
                              href={link.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-0.5 text-xs text-blue-600 transition-colors hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
                            >
                              {link.label}
                              <svg
                                class="h-3 w-3"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2.5"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                                />
                              </svg>
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                    <div class="flex flex-wrap gap-1">
                      {project.platforms.map((p) => (
                        <span class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wide text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                          {platformShort[p] || p}
                        </span>
                      ))}
                    </div>
                  </div>

                  <p class="mt-2 text-sm leading-snug text-gray-700 dark:text-gray-300">
                    {project.description}
                  </p>

                  <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                    {project.highlights && project.highlights.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {project.highlights.map((h) => (
                          <span class="inline-flex items-center gap-1 text-xs font-medium text-blue-700 dark:text-blue-400">
                            <svg
                              class="h-3 w-3"
                              fill="currentColor"
                              viewBox="0 0 20 20"
                            >
                              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            {h}
                          </span>
                        ))}
                      </div>
                    )}
                    {project.highlights &&
                      project.highlights.length > 0 &&
                      project.tags.length > 0 && (
                        <span class="text-xs text-gray-300 dark:text-gray-700">
                          •
                        </span>
                      )}
                    <div class="flex flex-wrap gap-1.5">
                      {project.tags.map((tag) => (
                        <span class="text-xs text-gray-500 dark:text-gray-500">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
