---
const highlights = [
  {
    title: "Cross-platform Mobile",
    description:
      "Shipped Flutter apps to phone, tablet, macOS, Android TV, and Amazon FireOS. Native Kotlin, Java, and Swift bridges for protocol clients, payment SDKs, and ad SDKs.",
    icon: "mobile",
  },
  {
    title: "Security & Networking",
    description:
      "DPI bypass via obfuscated protocol clients (IPsec, V2Ray, WireGuard, OpenVPN). DNS-over-HTTPS, certificate pinning, encrypted private key management.",
    icon: "shield",
  },
  {
    title: "Payments & Web3",
    description:
      "Bkash, SSL Commerz, Stripe, RevenueCat, Play Billing, StoreKit. Architected a non-custodial Web3 wallet on Polygon with fiat on/off-ramp integrations.",
    icon: "wallet",
  },
  {
    title: "Product Thinking",
    description:
      "Introduced analytics tooling (Microsoft Clarity, CleverTap), set up user feedback loops via Reddit and Telegram, and shipped 2-3 user-driven features per quarter.",
    icon: "compass",
  },
];

const icons: Record<string, string> = {
  mobile:
    "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
  shield:
    "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  wallet:
    "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z",
  compass:
    "M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z",
};
---

<section id="highlights" class="px-6 py-24">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-2xl font-bold tracking-tight">What I Bring</h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        highlights.map((h) => (
          <div class="rounded-xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-blue-50 text-blue-600 dark:bg-blue-950 dark:text-blue-400">
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={icons[h.icon]}
                />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-gray-100">
              {h.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
              {h.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
